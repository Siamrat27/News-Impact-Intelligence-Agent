# Supabase Postgres connection string
# (Supabase dashboard -> Project Settings -> Database -> Connection string, URI)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# LLM for sentiment scoring / agent reasoning (Phase 7+).
# Provider is env-driven and free-tier friendly; Groq is the default.
# Get a free key at https://console.groq.com/keys
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=
# Alternative: LLM_PROVIDER=anthropic + LLM_MODEL=claude-haiku-4-5 + key below
# ANTHROPIC_API_KEY=

# Embeddings need no key — fastembed runs a local ONNX model (bge-small-en-v1.5)
